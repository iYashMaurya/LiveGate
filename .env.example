# Required for AI-powered analysis (diff understanding, edge case generation, semantic comparison, verdict commentary)
ANTHROPIC_API_KEY=your_key_here

# Staging environment to probe
STAGING_BASE_URL=http://localhost:3001

# Log source: file | otel
LOG_SOURCE=file
LOG_PATH=./demo/sample-logs/access.log

# Optional: Jaeger URL for OTel trace mining
JAEGER_URL=http://localhost:16686

# Optional: GitHub PR commenting
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
PR_NUMBER=
