# ── Lyzr Studio (REQUIRED for AI-powered analysis) ───────────────────────
# Get these from studio.lyzr.ai
# Step 1: Create the LiveGate agent (see lyzr/README.md)
# Step 2: Copy your API key from Account & API Key settings
LYZR_API_KEY=your_lyzr_api_key_here
LYZR_AGENT_ID=your_lyzr_agent_id_here

# ── Staging Environment (REQUIRED) ───────────────────────────────────────
STAGING_BASE_URL=http://localhost:3001

# ── Log Source ────────────────────────────────────────────────────────────
LOG_SOURCE=file
LOG_PATH=./demo/sample-logs/access.log

# ── OTel / Jaeger (optional, enables real trace mining) ──────────────────
JAEGER_URL=http://localhost:16686

# ── GitHub PR Comments (optional) ────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
PR_NUMBER=
